{
  "$schema": "https://qooxdoo.org/schema/compile-1-0-0.json",
  "targets": [
    {
      "type": "source",
      "outputPath": "compiled/source",
      "bundle": {
        "include": "qx.*"
      }
    },
    {
      "type": "build",
      "outputPath": "compiled/build"
    },
    {
      "type": "build",
      "outputPath": "phonegap_wax/www"
    }
  ],
  "defaultTarget": "source",
  "locales": ["en"],
  "applications": [
    {
      "class": "wax.Application",
      "theme": "wax.theme.Theme",
      "name": "wax",
      "bootPath": "source/boot"
    }
  ]
}